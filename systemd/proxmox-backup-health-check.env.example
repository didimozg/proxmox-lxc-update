# Copy this file to:
#   /etc/default/proxmox-backup-health-check
#
# Then adjust the values for your environment.

SCRIPT_PATH=/media/script/backup_health_check.sh
LOG_FILE=/var/log/pve-backup-health-check.log

# Optional extra script arguments.
# Keep this space-separated because the systemd service splits it into words.
BACKUP_HEALTH_CHECK_ARGS=

# Telegram notifications.
# The bot must be started by the destination user before messages can be delivered.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Telegram forum topic/thread ID.
TELEGRAM_THREAD_ID=

# 1 = notify for OK/WARN/CRIT/ERROR
# 0 = notify only for WARN/CRIT/ERROR
TELEGRAM_NOTIFY_ON_OK=1
TELEGRAM_TIMEOUT=15
